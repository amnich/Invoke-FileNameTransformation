<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:primitives="clr-namespace:System.Windows.Controls.Primitives;assembly=PresentationFramework"
        Title="{t:WinTitle}" Height="{ScreenHeight}" Width="{ScreenWidth}"
        MinHeight="600" MinWidth="1000"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI" FontSize="13"
        Background="{DynamicResource BgWindow}" Foreground="{DynamicResource TextPrimary}">
  <Window.Resources>
    <!-- Default Color Brushes -->
    <SolidColorBrush x:Key="BgWindow" Color="#121417"/>
    <SolidColorBrush x:Key="BgPanel" Color="#1E2228"/>
    <SolidColorBrush x:Key="BgHeader" Color="#181B20"/>
    <SolidColorBrush x:Key="BgControl" Color="#282C34"/>
    <SolidColorBrush x:Key="BgControlHover" Color="#323842"/>
    <SolidColorBrush x:Key="TextPrimary" Color="#E6EDF3"/>
    <SolidColorBrush x:Key="TextSecondary" Color="#A0AEC0"/>
    <SolidColorBrush x:Key="TextMuted" Color="#718096"/>
    <SolidColorBrush x:Key="BorderBrush" Color="#3A414D"/>
    <SolidColorBrush x:Key="ControlBorder" Color="#4A5568"/>
    <SolidColorBrush x:Key="GridAltRow" Color="#23272F"/>
    <SolidColorBrush x:Key="GridRowHover" Color="#2D333B"/>
    <SolidColorBrush x:Key="GridHeaderBg" Color="#252930"/>
    <SolidColorBrush x:Key="AccentColor" Color="#63B3ED"/>
    <SolidColorBrush x:Key="AccentButtonBg" Color="#2B4C7E"/>
    <SolidColorBrush x:Key="AccentButtonFg" Color="#EBF8FF"/>
    <SolidColorBrush x:Key="SuccessButtonBg" Color="#1E4620"/>
    <SolidColorBrush x:Key="SuccessButtonFg" Color="#C6F6D5"/>
    <SolidColorBrush x:Key="RowSuccessBg" Color="#17341A"/>
    <SolidColorBrush x:Key="RowErrorBg" Color="#4A1D1D"/>
    <SolidColorBrush x:Key="RowWarningBg" Color="#4A3515"/>
    <SolidColorBrush x:Key="PreviewBoxBg" Color="#1A202C"/>
    <SolidColorBrush x:Key="PreviewBoxBorder" Color="#4A5568"/>
    <SolidColorBrush x:Key="ListBoxSelectionBg" Color="#2B6CB0"/>
    <SolidColorBrush x:Key="ListBoxSelectionFg" Color="#FFFFFF"/>
    <SolidColorBrush x:Key="TabSelectedBg" Color="#1E2228"/>
    <SolidColorBrush x:Key="TabSelectedFg" Color="#63B3ED"/>
    <SolidColorBrush x:Key="TabUnselectedFg" Color="#A0AEC0"/>

    <!-- General Control Styles -->
    <Style TargetType="Label">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style TargetType="TextBlock">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style TargetType="CheckBox">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style TargetType="Separator">
      <Setter Property="Background" Value="{DynamicResource BorderBrush}"/>
    </Style>

    <!-- GroupBox Style -->
    <Style TargetType="GroupBox">
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="GroupBox">
            <Grid>
              <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
              </Grid.RowDefinitions>
              <Border Grid.RowSpan="2" CornerRadius="4" BorderThickness="1"
                      BorderBrush="{TemplateBinding BorderBrush}"
                      Background="{TemplateBinding Background}"/>
              <Border Grid.Row="0" Margin="8,4,8,0" Padding="4,2">
                <ContentPresenter ContentSource="Header" RecognizesAccessKey="True"/>
              </Border>
              <ContentPresenter Grid.Row="1" Margin="8"/>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- Button Style -->
    <Style TargetType="Button">
      <Setter Property="Margin" Value="4"/>
      <Setter Property="Padding" Value="10,5"/>
      <Setter Property="MinHeight" Value="30"/>
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="Button">
            <Border Name="border" Background="{TemplateBinding Background}"
                    BorderBrush="{TemplateBinding BorderBrush}"
                    BorderThickness="1" CornerRadius="3"
                    Padding="{TemplateBinding Padding}">
              <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="border" Property="Background" Value="{DynamicResource BgControlHover}"/>
              </Trigger>
              <Trigger Property="IsEnabled" Value="False">
                <Setter TargetName="border" Property="Opacity" Value="0.5"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <Style x:Key="AccentButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{DynamicResource AccentButtonBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource AccentButtonFg}"/>
    </Style>

    <Style x:Key="SuccessButton" TargetType="Button" BasedOn="{StaticResource {x:Type Button}}">
      <Setter Property="Background" Value="{DynamicResource SuccessButtonBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource SuccessButtonFg}"/>
    </Style>

    <!-- TextBox Style -->
    <Style TargetType="TextBox">
      <Setter Property="Margin" Value="4"/>
      <Setter Property="Padding" Value="5"/>
      <Setter Property="VerticalContentAlignment" Value="Center"/>
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
      <Setter Property="CaretBrush" Value="{DynamicResource TextPrimary}"/>
    </Style>

    <!-- ComboBox Item Style -->
    <Style TargetType="ComboBoxItem">
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBoxItem">
            <Border Name="Bd" Background="{TemplateBinding Background}" Padding="{TemplateBinding Padding}">
              <ContentPresenter/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgControlHover}"/>
              </Trigger>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource ListBoxSelectionBg}"/>
                <Setter Property="Foreground" Value="{DynamicResource ListBoxSelectionFg}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ComboBox ControlTemplate (Skill Rule #2) -->
    <Style TargetType="ComboBox">
      <Setter Property="Margin" Value="4"/>
      <Setter Property="MinHeight" Value="29"/>
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource ControlBorder}"/>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="ComboBox">
            <Grid>
              <ToggleButton Name="ToggleButton" Focusable="False"
                            IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                            ClickMode="Press" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}">
                <ToggleButton.Template>
                  <ControlTemplate TargetType="ToggleButton">
                    <Border Name="Border" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="3">
                      <Grid HorizontalAlignment="Right" Width="20">
                        <Path Name="Arrow" Data="M 0 0 L 4 4 L 8 0 Z" Fill="{DynamicResource TextPrimary}"
                              HorizontalAlignment="Center" VerticalAlignment="Center"/>
                      </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                      <Trigger Property="IsMouseOver" Value="True">
                        <Setter TargetName="Border" Property="Background" Value="{DynamicResource BgControlHover}"/>
                      </Trigger>
                    </ControlTemplate.Triggers>
                  </ControlTemplate>
                </ToggleButton.Template>
              </ToggleButton>
              <ContentPresenter Name="ContentSite" IsHitTestVisible="False"
                                Content="{TemplateBinding SelectionBoxItem}"
                                ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                ContentTemplateSelector="{TemplateBinding ItemTemplateSelector}"
                                Margin="8,3,23,3" VerticalAlignment="Center" HorizontalAlignment="Left"/>
              <Popup Name="Popup" Placement="Bottom" IsOpen="{TemplateBinding IsDropDownOpen}"
                     AllowsTransparency="True" Focusable="False" PopupAnimation="Slide">
                <Grid Name="DropDown" SnapsToDevicePixels="True"
                      MinWidth="{TemplateBinding ActualWidth}" MaxHeight="{TemplateBinding MaxDropDownHeight}">
                  <Border Name="DropDownBorder" Background="{DynamicResource BgControl}"
                          BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" CornerRadius="3">
                    <ScrollViewer Margin="4,6" SnapsToDevicePixels="True">
                      <StackPanel IsItemsHost="True" KeyboardNavigation.DirectionalNavigation="Contained"/>
                    </ScrollViewer>
                  </Border>
                </Grid>
              </Popup>
            </Grid>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- ListBox and ListBoxItem Style -->
    <Style TargetType="ListBox">
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style TargetType="ListBoxItem">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Padding" Value="4,2"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource ListBoxSelectionBg}"/>
          <Setter Property="Foreground" Value="{DynamicResource ListBoxSelectionFg}"/>
        </Trigger>
        <Trigger Property="IsMouseOver" Value="True">
          <Setter Property="Background" Value="{DynamicResource BgControlHover}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- DataGrid Styles -->
    <Style TargetType="DataGrid">
      <Setter Property="Margin" Value="4"/>
      <Setter Property="IsReadOnly" Value="True"/>
      <Setter Property="CanUserAddRows" Value="False"/>
      <Setter Property="AutoGenerateColumns" Value="False"/>
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="RowBackground" Value="{DynamicResource BgPanel}"/>
      <Setter Property="AlternatingRowBackground" Value="{DynamicResource GridAltRow}"/>
      <Setter Property="HorizontalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="VerticalGridLinesBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style TargetType="DataGridColumnHeader">
      <Setter Property="Background" Value="{DynamicResource GridHeaderBg}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Padding" Value="6,4"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
      <Setter Property="BorderThickness" Value="0,0,1,1"/>
    </Style>
    <Style TargetType="DataGridCell">
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="Padding" Value="4,2"/>
      <Setter Property="BorderThickness" Value="0"/>
      <Style.Triggers>
        <Trigger Property="IsSelected" Value="True">
          <Setter Property="Background" Value="{DynamicResource ListBoxSelectionBg}"/>
          <Setter Property="Foreground" Value="{DynamicResource ListBoxSelectionFg}"/>
        </Trigger>
      </Style.Triggers>
    </Style>

    <!-- TabControl and TabItem Styles -->
    <Style TargetType="TabControl">
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style TargetType="TabItem">
      <Setter Property="HeaderTemplate">
        <Setter.Value>
          <DataTemplate>
            <ContentPresenter Content="{Binding}"/>
          </DataTemplate>
        </Setter.Value>
      </Setter>
      <Setter Property="Template">
        <Setter.Value>
          <ControlTemplate TargetType="TabItem">
            <Border Name="Border" Background="{DynamicResource BgHeader}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="1,1,1,0" CornerRadius="4,4,0,0" Padding="12,6" Margin="0,0,2,0">
              <ContentPresenter Name="ContentSite" VerticalAlignment="Center" HorizontalAlignment="Center"
                                ContentSource="Header" TextElement.Foreground="{DynamicResource TabUnselectedFg}"/>
            </Border>
            <ControlTemplate.Triggers>
              <Trigger Property="IsSelected" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource TabSelectedBg}"/>
                <Setter TargetName="Border" Property="BorderThickness" Value="1,1,1,0"/>
                <Setter TargetName="ContentSite" Property="TextElement.Foreground" Value="{DynamicResource TabSelectedFg}"/>
                <Setter TargetName="ContentSite" Property="TextElement.FontWeight" Value="SemiBold"/>
              </Trigger>
              <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="Background" Value="{DynamicResource BgControlHover}"/>
              </Trigger>
            </ControlTemplate.Triggers>
          </ControlTemplate>
        </Setter.Value>
      </Setter>
    </Style>

    <!-- DatePicker and Calendar Implicit Styles (Skill Rule #3) -->
    <Style TargetType="{x:Type primitives:DatePickerTextBox}">
      <Setter Property="Background" Value="{DynamicResource BgControl}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderThickness" Value="0"/>
    </Style>
    <Style TargetType="Calendar">
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
      <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
    </Style>
    <Style TargetType="CalendarItem">
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style TargetType="CalendarDayButton">
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>
    <Style TargetType="CalendarButton">
      <Setter Property="Background" Value="{DynamicResource BgPanel}"/>
      <Setter Property="Foreground" Value="{DynamicResource TextPrimary}"/>
    </Style>

  </Window.Resources>

  <DockPanel Background="{DynamicResource BgWindow}">
    <!-- Status bar -->
    <Border DockPanel.Dock="Bottom" Background="{DynamicResource BgHeader}" Padding="9" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0">
      <DockPanel>
        <TextBlock x:Name="StatusText"/>
        <TextBlock x:Name="LogText" DockPanel.Dock="Right" Foreground="{DynamicResource TextSecondary}"/>
        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,15,0">
          <Label Content="{t:Lbl_Language}" VerticalAlignment="Center" Padding="0" Margin="0,0,4,0"/>
          <ComboBox x:Name="LanguageSelector" Width="100" MinHeight="22" Padding="4,2">
            <ComboBoxItem Content="Polski" Tag="PL"/>
            <ComboBoxItem Content="English" Tag="EN"/>
            <ComboBoxItem Content="Deutsch" Tag="DE"/>
          </ComboBox>
          <Label Content="{t:Lbl_Theme}" VerticalAlignment="Center" Padding="0" Margin="10,0,4,0"/>
          <ComboBox x:Name="ThemeSelector" Width="100" MinHeight="22" Padding="4,2">
            <ComboBoxItem Content="{t:Theme_Dark}" Tag="Dark"/>
            <ComboBoxItem Content="{t:Theme_Light}" Tag="Light"/>
          </ComboBox>
        </StackPanel>
      </DockPanel>
    </Border>

    <Grid Margin="8">
      <Grid.RowDefinitions>
        <RowDefinition Height="Auto"/>
        <RowDefinition Height="*"/>
      </Grid.RowDefinitions>

      <!-- Folders -->
      <GroupBox Grid.Row="0" Header="{t:Folders_Header}">
        <Grid>
          <Grid.ColumnDefinitions>
            <ColumnDefinition Width="150"/>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="110"/>
          </Grid.ColumnDefinitions>
          <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
          </Grid.RowDefinitions>
          <Label Grid.Row="0" Content="{t:Source_Folder}"/>
          <TextBox x:Name="SourcePath" Grid.Row="0" Grid.Column="1"/>
          <Popup x:Name="SourcePathSuggestions" PlacementTarget="{Binding ElementName=SourcePath}"
                 Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Width="520" MaxHeight="180" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <ListBox x:Name="SourcePathSuggestionList" MaxHeight="178"/>
            </Border>
          </Popup>
          <Button x:Name="BrowseSource" Grid.Row="0" Grid.Column="2" Content="{t:Btn_Browse}"/>
          <Label Grid.Row="1" Content="{t:Dest_Folder}"/>
          <TextBox x:Name="DestinationPath" Grid.Row="1" Grid.Column="1"/>
          <Popup x:Name="DestinationPathSuggestions" PlacementTarget="{Binding ElementName=DestinationPath}"
                 Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
            <Border Width="520" MaxHeight="180" Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
              <ListBox x:Name="DestinationPathSuggestionList" MaxHeight="178"/>
            </Border>
          </Popup>
          <Button x:Name="BrowseDestination" Grid.Row="1" Grid.Column="2" Content="{t:Btn_Browse}"/>
          <CheckBox x:Name="Recursive" Grid.Row="2" Grid.Column="1"
                    Content="{t:Chk_Recursive}"
                    Margin="4,2,4,4" VerticalAlignment="Center"/>
          <CheckBox x:Name="PreserveFolderStructure" Grid.Row="3" Grid.Column="1"
                    Content="{t:Chk_PreserveStructure}" IsChecked="True"
                    Margin="4,2,4,4" VerticalAlignment="Center"/>
        </Grid>
      </GroupBox>

      <!-- Tabs -->
      <TabControl Grid.Row="1" Margin="4">

        <!-- BGH_COMPLIANCE_START -->
        <!-- ========== 0. Compliance ========== -->
        <TabItem Header="{t:Tab_Compliance}">
          <DockPanel Margin="8">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,8">
              <Button x:Name="ComplianceScan" Content="{t:Btn_ScanCompliance}" Style="{StaticResource AccentButton}"/>
              <TextBlock Text="{t:Txt_Extension}" Margin="14,8,4,0"/>
              <ComboBox x:Name="ComplianceExtFilter" Width="100" VerticalAlignment="Center"/>
              <TextBlock x:Name="ComplianceInfo" Margin="14,8,4,4" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Bottom" Margin="0,8,0,0">
              <WrapPanel HorizontalAlignment="Right">
                <Button x:Name="ComplianceFixSelected" Content="{t:Btn_FixSelected}" Style="{StaticResource SuccessButton}"/>
              </WrapPanel>
            </StackPanel>
            <DataGrid x:Name="ComplianceGrid" AutoGenerateColumns="False" IsReadOnly="True" SelectionMode="Extended">
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Setter Property="ToolTip" Value="{Binding Details}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding IsCompliant}" Value="True">
                      <Setter Property="Background" Value="{DynamicResource RowSuccessBg}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding IsCompliant}" Value="False">
                      <Setter Property="Background" Value="{DynamicResource RowWarningBg}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="{t:Col_SourceFile}" Binding="{Binding FileName}" Width="2*"/>
                <DataGridTextColumn Header="{t:Col_Status}" Binding="{Binding StatusText}" Width="90"/>
                <DataGridTextColumn Header="{t:Col_MetaDate}" Binding="{Binding MetaDate}" Width="110"/>
                <DataGridTextColumn Header="{t:Col_MetaAuthor}" Binding="{Binding MetaAuthor}" Width="140"/>
                <DataGridTextColumn Header="{t:Col_Violations}" Binding="{Binding ViolationText}" Width="2*"/>
                <DataGridTextColumn Header="{t:Col_SuggestedName}" Binding="{Binding SuggestedName}" Width="2*"/>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </TabItem>
        <!-- BGH_COMPLIANCE_END -->

        <!-- ========== 1. Profile ========== -->
        <TabItem Header="{t:Tab_Profile}">
          <Grid Margin="12">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="380"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <GroupBox Header="{t:Saved_Profiles}" Grid.Column="0">
              <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                  <WrapPanel>
                    <Button x:Name="ProfileNew"    Content="{t:Btn_New}"/>
                    <Button x:Name="ProfileLoad"   Content="{t:Btn_Load}"/>
                    <Button x:Name="ProfileCopy"   Content="{t:Btn_Copy}"/>
                    <Button x:Name="ProfileDelete" Content="{t:Btn_Delete}"/>
                  </WrapPanel>
                  <Button x:Name="ProfileSave" Content="{t:Btn_Save_Config}" Style="{StaticResource AccentButton}"/>
                </StackPanel>
                <ListBox x:Name="ProfileList" DisplayMemberPath="Name"/>
              </DockPanel>
            </GroupBox>
            <StackPanel Grid.Column="1" Margin="20,0,0,0">
              <TextBlock FontSize="18" FontWeight="SemiBold" Text="{t:Title_Wizard}"/>
              <TextBlock Margin="0,12,0,0" TextWrapping="Wrap"
                         Text="{t:Txt_ProfileHint}"/>
              <TextBlock Margin="0,18,0,0" FontWeight="SemiBold" Text="{t:Txt_ActiveProfile}"/>
              <TextBlock x:Name="CurrentProfile" Margin="0,4,0,0" Text="{t:Txt_Unsaved}"/>
            </StackPanel>
          </Grid>
        </TabItem>

        <!-- ========== 2. File analysis ========== -->
        <TabItem Header="{t:Tab_Analysis}">
          <Grid Margin="8">
            <Grid.RowDefinitions>
              <RowDefinition Height="Auto"/>
              <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <WrapPanel>
              <Button x:Name="Analyze" Content="{t:Btn_Analyze}" Style="{StaticResource AccentButton}"/>
              <TextBlock Text="{t:Txt_Extension}" Margin="14,9,0,0"/>
              <ComboBox x:Name="ExtensionFilter" Width="130"/>
              <TextBlock Text="{t:Txt_TokenRegex}" Margin="14,9,0,0" Foreground="{DynamicResource TextSecondary}" ToolTip="{t:Tip_TokenRegexLabel}"/>
              <TextBox x:Name="TokenRegex" Width="400" Text="(?&lt;value&gt;[^_\-\s]+)|(?&lt;sep&gt;[_\-\s]+)" ToolTip="{t:Tip_TokenRegex}" FontFamily="Consolas"/>
              <TextBlock x:Name="AnalysisInfo" Margin="14,9,0,0"/>
            </WrapPanel>
            <Grid Grid.Row="1">
              <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="*"/>
              </Grid.ColumnDefinitions>
              <GroupBox Grid.Column="0" Header="{t:Header_DetectedStructs}">
                <DataGrid x:Name="PatternGrid" SelectionMode="Single">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="{t:Col_Extension}" Binding="{Binding Extension}" Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Structure}"    Binding="{Binding Display}"   Width="3*"/>
                    <DataGridTextColumn Header="{t:Col_Files}"        Binding="{Binding Count}"     Width="*"/>
                  </DataGrid.Columns>
                </DataGrid>
              </GroupBox>
              <GroupBox Grid.Column="1" Header="{t:Header_Examples}">
                <DockPanel>
                  <TextBlock x:Name="PatternHint" DockPanel.Dock="Bottom" Margin="4"
                             TextWrapping="Wrap" Foreground="{DynamicResource TextSecondary}"/>
                  <ListBox x:Name="PatternSamples"/>
                </DockPanel>
              </GroupBox>
            </Grid>
          </Grid>
        </TabItem>

        <!-- ========== 3. Fields and mappings ========== -->
        <TabItem Header="{t:Tab_Fields}">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: field table -->
            <GroupBox Grid.Column="0" Header="{t:Header_DetectedFields}">
              <DockPanel>
                <TextBlock DockPanel.Dock="Bottom" Margin="4" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"
                           Text="{t:Txt_FieldHint}"/>
                <DataGrid x:Name="FieldGrid" SelectionMode="Single">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="#"        Binding="{Binding DisplayIndex}" Width="30"/>
                    <DataGridTextColumn Header="{t:Col_Sample}" Binding="{Binding Sample}"       Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Type}"      Binding="{Binding EffectiveType}" Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Status}" Binding="{Binding TypeStatus}" Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Name}"    Binding="{Binding Name}"         Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Role}"     Binding="{Binding Role}"         Width="*"/>
                    <DataGridTextColumn Header="{t:Col_Source}"   Binding="{Binding Source}"       Width="72"/>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </GroupBox>

            <!-- Right: field editing -->
            <GroupBox Grid.Column="1" Header="{t:Header_EditField}">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="4">
                  <TextBlock Text="{t:Txt_FieldName}" Margin="0,0,0,2"/>
                  <TextBox x:Name="FieldName"/>
                  <TextBlock Text="{t:Txt_Role}" Margin="0,4,0,2"/>
                  <ComboBox x:Name="FieldRole">
                    <ComboBoxItem Content="{t:Role_Value}"/>
                    <ComboBoxItem Content="{t:Role_Date}"/>
                    <ComboBoxItem Content="{t:Role_Id}"/>
                    <ComboBoxItem Content="{t:Role_Const}"/>
                    <ComboBoxItem Content="{t:Role_Ignore}"/>
                  </ComboBox>
                  <TextBlock Text="{t:Txt_DataType}" Margin="0,4,0,2"/>
                  <ComboBox x:Name="FieldType" DisplayMemberPath="Label"/>
                  <TextBlock Text="{t:Txt_Candidates}" Margin="0,4,0,2"/>
                  <TextBlock x:Name="CandidateInfo" Margin="4,0,4,4" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap"/>
                  <Button x:Name="FieldApply" Content="{t:Btn_ApplyField}" Margin="4,6,4,4"/>

                  <Separator Margin="4,8"/>

                  <!-- Per-field transforms -->
                  <TextBlock FontWeight="Bold" Text="{t:Header_Transformations}" Margin="0,4,0,4"/>
                  <TextBlock Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" FontSize="11.5"
                             Text="{t:Txt_TransformHint}"/>
                  <ListBox x:Name="TransformList" DisplayMemberPath="Display" Height="105" Margin="4"/>
                  <WrapPanel>
                    <Button x:Name="TransformAdd"    Content="{t:Btn_AddTransform}"/>
                    <Button x:Name="TransformRemove" Content="{t:Btn_Delete}"/>
                  </WrapPanel>

                  <Separator Margin="4,8"/>

                  <!-- Global mappings -->
                  <TextBlock FontWeight="Bold" Text="{t:Header_Mappings}" Margin="0,4,0,4"/>
                  <TextBlock Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" FontSize="11.5"
                             Text="{t:Txt_MappingHint}"/>
                  <ListBox x:Name="MappingList" DisplayMemberPath="Display" Height="105" Margin="4"/>
                  <WrapPanel>
                    <Button x:Name="MappingAdd"    Content="{t:Btn_AddMapping}"/>
                    <Button x:Name="MappingEdit"   Content="{t:Btn_Edit}"/>
                    <Button x:Name="MappingRemove" Content="{t:Btn_Delete}"/>
                    <Button x:Name="MappingUp"     Content="{t:Btn_Up}"/>
                    <Button x:Name="MappingDown"   Content="{t:Btn_Down}"/>
                  </WrapPanel>
                </StackPanel>
              </ScrollViewer>
            </GroupBox>
          </Grid>
        </TabItem>

        <!-- ========== 4. Destination name ========== -->
        <TabItem Header="{t:Tab_DestName}">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="*"/>
              <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- Left: name builder -->
            <GroupBox Grid.Column="0" Header="{t:Header_DestElements}">
              <DockPanel>
                <StackPanel DockPanel.Dock="Bottom">
                  <WrapPanel Margin="0,4,0,0">
                    <ComboBox x:Name="FieldSelector" Width="240"/>
                    <Button x:Name="OutputAddField" Content="{t:Btn_AddField}"/>
                  </WrapPanel>
                  <WrapPanel>
                    <TextBox x:Name="OutputText" Width="240"/>
                    <Button x:Name="OutputAddText"      Content="{t:Btn_AddText}"/>
                    <Button x:Name="OutputAddSeparator" Content="{t:Btn_AddSep}"/>
                  </WrapPanel>
                  <WrapPanel>
                    <Button x:Name="OutputUp"     Content="{t:Btn_Up}"/>
                    <Button x:Name="OutputDown"   Content="{t:Btn_Down}"/>
                    <Button x:Name="OutputRemove" Content="{t:Btn_RemoveElement}"/>
                  </WrapPanel>
                </StackPanel>
                <ListBox x:Name="OutputList" DisplayMemberPath="Display"/>
              </DockPanel>
            </GroupBox>

            <!-- Right: extension settings and preview -->
            <GroupBox Grid.Column="1" Header="{t:Header_Settings}">
              <StackPanel Margin="4">
                <WrapPanel>
                  <CheckBox x:Name="KeepExtension" IsChecked="True"
                            Content="{t:Chk_KeepExt}" Margin="4"/>
                </WrapPanel>
                <WrapPanel>
                  <TextBlock Text="{t:Txt_NewExt}" Margin="10,8,4,0"/>
                  <TextBox x:Name="NewExtension" Width="120" IsEnabled="False"/>
                </WrapPanel>

                <Separator Margin="4,12"/>

                <TextBlock FontWeight="Bold" Text="{t:Txt_PreviewTitle}" Margin="0,4,0,8"/>
                <Border Background="{DynamicResource PreviewBoxBg}" BorderBrush="{DynamicResource PreviewBoxBorder}" BorderThickness="1"
                        Padding="10" CornerRadius="4">
                  <TextBlock x:Name="OutputExample" TextWrapping="Wrap"
                             FontFamily="Consolas" FontSize="13"/>
                </Border>
              </StackPanel>
            </GroupBox>
          </Grid>
        </TabItem>

        <!-- ========== 5. Preview and execution ========== -->
        <TabItem Header="{t:Tab_Preview}">
          <DockPanel Margin="8">
            <StackPanel DockPanel.Dock="Top" Orientation="Horizontal">
              <Button x:Name="BuildPreview" Content="{t:Btn_BuildPreview}" Style="{StaticResource AccentButton}"/>
              <CheckBox x:Name="EnforcePattern" Content="{t:Chk_EnforcePattern}" Margin="10,0" VerticalAlignment="Center"/>
              <ComboBox x:Name="PreviewFilter" Width="150">
                <ComboBoxItem Content="{t:Cbo_All}" IsSelected="True"/>
                <ComboBoxItem Content="{t:Cbo_Errors}"/>
                <ComboBoxItem Content="{t:Cbo_Ready}"/>
              </ComboBox>
              <TextBlock x:Name="PreviewInfo" Margin="12,10,4,4"/>
            </StackPanel>
            <StackPanel DockPanel.Dock="Bottom">
              <ProgressBar x:Name="ProgressBar" Height="18" Margin="4" Visibility="Collapsed"/>
              <WrapPanel HorizontalAlignment="Right">
                <TextBlock Text="{t:Lbl_ExecutionMode}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                <ComboBox x:Name="ExecutionMode" Width="110" Margin="0,0,8,0">
                  <ComboBoxItem Content="{t:Action_Copy}" IsSelected="True"/>
                  <ComboBoxItem Content="{t:Action_Move}"/>
                </ComboBox>
                <Button x:Name="ExportAudit" Content="{t:Btn_Export}"/>
                <Button x:Name="OpenLog"     Content="{t:Btn_OpenLog}"/>
                <Button x:Name="Execute"     Content="{t:Btn_Execute}" Style="{StaticResource SuccessButton}"/>
              </WrapPanel>
            </StackPanel>
            <DataGrid x:Name="PreviewGrid">
              <DataGrid.RowStyle>
                <Style TargetType="DataGridRow">
                  <Setter Property="ToolTip" Value="{Binding Details}"/>
                  <Style.Triggers>
                    <DataTrigger Binding="{Binding StatusCode}" Value="Error">
                      <Setter Property="Background" Value="{DynamicResource RowErrorBg}"/>
                    </DataTrigger>
                    <DataTrigger Binding="{Binding StatusCode}" Value="Ready">
                      <Setter Property="Background" Value="{DynamicResource RowSuccessBg}"/>
                    </DataTrigger>
                  </Style.Triggers>
                </Style>
              </DataGrid.RowStyle>
              <DataGrid.Columns>
                <DataGridTextColumn Header="{t:Col_SourceFile}"  Binding="{Binding SourceRelative}"      Width="2*"/>
                <DataGridTextColumn Header="{t:Col_DestName}" Binding="{Binding DestinationRelative}"  Width="2*"/>
                <DataGridTextColumn Header="{t:Col_Status}"         Binding="{Binding Status}"               Width="80"/>
                <DataGridTextColumn Header="{t:Col_Details}"      Binding="{Binding Details}"              Width="3*"/>
              </DataGrid.Columns>
            </DataGrid>
          </DockPanel>
        </TabItem>

        <!-- ========== 6. Custom Rules ========== -->
        <TabItem Header="{t:Tab_CustomRules}">
          <Grid Margin="8">
            <Grid.ColumnDefinitions>
              <ColumnDefinition Width="3*"/>
              <ColumnDefinition Width="2*"/>
            </Grid.ColumnDefinitions>

            <!-- Left side: Custom rules table -->
            <GroupBox Grid.Column="0" Header="{t:Header_CustomRules}">
              <DockPanel>
                <TextBlock DockPanel.Dock="Top" Margin="4,2,4,6" Foreground="{DynamicResource TextSecondary}" TextWrapping="Wrap" Text="{t:Txt_CustomRulesHint}"/>
                <WrapPanel DockPanel.Dock="Bottom" Margin="0,4,0,0">
                  <Button x:Name="CustomRuleNew" Content="{t:Btn_NewRule}"/>
                  <Button x:Name="CustomRuleDelete" Content="{t:Btn_Delete}"/>
                  <Button x:Name="CustomRuleSaveConfig" Content="{t:Btn_Save_Config}" Style="{StaticResource AccentButton}"/>
                  <Button x:Name="OpenCustomRulesDoc" Content="{t:Btn_OpenRulesDoc}"/>
                </WrapPanel>
                <DataGrid x:Name="CustomRulesGrid" SelectionMode="Single">
                  <DataGrid.Columns>
                    <DataGridTextColumn Header="ID" Binding="{Binding Id}" Width="110"/>
                    <DataGridTextColumn Header="{t:Col_DisplayName}" Binding="{Binding DisplayName}" Width="130"/>
                    <DataGridTextColumn Header="{t:Col_Pattern}" Binding="{Binding Pattern}" Width="2*"/>
                    <DataGridCheckBoxColumn Header="{t:Col_Enabled}" Binding="{Binding Enabled}" Width="65"/>
                    <DataGridCheckBoxColumn Header="{t:Col_AllowComposite}" Binding="{Binding AllowComposite}" Width="105"/>
                  </DataGrid.Columns>
                </DataGrid>
              </DockPanel>
            </GroupBox>

            <!-- Right side: Edit and Live Regex Testing Form -->
            <GroupBox Grid.Column="1" Header="{t:Header_EditCustomRule}">
              <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="6">
                  <TextBlock Text="Rule ID:" Margin="0,2,0,2" FontWeight="SemiBold"/>
                  <TextBox x:Name="CustomRuleId"/>

                  <TextBlock Text="{t:Col_DisplayName}:" Margin="0,6,0,2" FontWeight="SemiBold"/>
                  <TextBox x:Name="CustomRuleDisplayName"/>

                  <TextBlock Text="Regex Pattern:" Margin="0,6,0,2" FontWeight="SemiBold"/>
                  <TextBox x:Name="CustomRulePattern" FontFamily="Consolas"/>

                  <CheckBox x:Name="CustomRuleEnabled" Content="{t:Col_Enabled}" IsChecked="True" Margin="4,8,4,4"/>
                  <CheckBox x:Name="CustomRuleAllowComposite" Content="{t:Col_AllowComposite}" Margin="4,2,4,8"/>

                  <Button x:Name="CustomRuleApply" Content="{t:Btn_ApplyRule}" Margin="0,6,0,8"/>

                  <Separator Margin="0,8"/>

                  <!-- Interactive Live Regex Testing Section -->
                  <TextBlock Text="{t:Header_TestCustomRule}" FontWeight="Bold" Margin="0,4,0,4"/>
                  <TextBlock Text="{t:Txt_TestSampleInput}" Margin="0,2,0,2"/>
                  <TextBox x:Name="CustomRuleTestInput" Text="Report_2026-01-16"/>
                  <Button x:Name="CustomRuleTestBtn" Content="{t:Btn_TestRule}" Margin="0,6,0,6"/>

                  <Border Background="{DynamicResource BgControl}" BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1" Padding="8" CornerRadius="4" Margin="0,4,0,0">
                    <TextBlock x:Name="CustomRuleTestResult" TextWrapping="Wrap" FontFamily="Consolas" FontSize="12"/>
                  </Border>
                </StackPanel>
              </ScrollViewer>
            </GroupBox>
          </Grid>
        </TabItem>

      </TabControl>
    </Grid>
  </DockPanel>
</Window>
